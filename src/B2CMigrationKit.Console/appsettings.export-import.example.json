{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "Migration": {
    "B2C": {
      "TenantId": "<your-b2c-tenant-id>",
      "TenantDomain": "<yourtenant>.onmicrosoft.com",
      "AppRegistration": {
        "ClientId": "<your-b2c-app-client-id>",
        "ClientSecret": "<your-b2c-app-client-secret>",
        "Name": "B2C App Registration",
        "Enabled": true
      },
      "Scopes": [ "https://graph.microsoft.com/.default" ]
    },
    "ExternalId": {
      "TenantId": "<your-externalid-tenant-id>",
      "TenantDomain": "<yourtenant>.onmicrosoft.com",
      "ExtensionAppId": "<extension-app-id-no-hyphens>",
      "AppRegistration": {
        "ClientId": "<your-externalid-app-client-id>",
        "ClientSecret": "<your-externalid-app-client-secret>",
        "Name": "External ID App Registration",
        "Enabled": true
      },
      "Scopes": [ "https://graph.microsoft.com/.default" ]
    },
    "Storage": {
      "ConnectionStringOrUri": "https://<your-storage-account>.blob.core.windows.net",
      "ExportContainerName": "user-exports",
      "ErrorContainerName": "migration-errors",
      "ImportAuditContainerName": "import-audit",
      "ExportBlobPrefix": "users_",
      "AuditTableName": "migrationAudit",
      "AuditMode": "File",
      "UseManagedIdentity": true
    },
    "Telemetry": {
      "ConnectionString": "",
      "Enabled": false,
      "UseApplicationInsights": false,
      "UseConsoleLogging": true
    },
    "Retry": {
      "MaxRetries": 5,
      "InitialDelayMs": 1000,
      "MaxDelayMs": 30000,
      "BackoffMultiplier": 2.0,
      "UseRetryAfterHeader": true,
      "OperationTimeoutSeconds": 120
    },
    "Export": {
      "SelectFields": "id,userPrincipalName,displayName,givenName,surname,mail,mobilePhone,identities",
      "MaxUsers": 0,
      "FilterPattern": ""
    },
    "Import": {
      "AttributeMappings": {},
      "ExcludeFields": [
        "createdDateTime",
        "lastPasswordChangeDateTime"
      ],
      "MigrationAttributes": {
        "StoreB2CObjectId": true,
        "SetRequireMigration": true,
        "OverwriteExtensionAttributes": false
      },
      "SkipPhoneRegistration": true
    },
    "BatchDelayMs": 0
  }
}
