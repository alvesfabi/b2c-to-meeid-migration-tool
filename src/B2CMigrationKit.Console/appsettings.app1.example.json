{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Migration": {
    "B2C": {
      "TenantId": "your-b2c-tenant-id",
      "TenantDomain": "your-tenant.onmicrosoft.com",
      "AppRegistration": {
        "ClientId": "app-registration-1-client-id",
        "ClientSecretName": "B2CAppSecret1",
        "Name": "B2C App Registration 1",
        "Enabled": true
      },
      "Scopes": [ "https://graph.microsoft.com/.default" ]
    },
    "ExternalId": {
      "TenantId": "your-external-id-tenant-id",
      "TenantDomain": "your-external-tenant.onmicrosoft.com",
      "ExtensionAppId": "00000000000000000000000000000000",
      "AppRegistration": {
        "ClientId": "app-registration-1-client-id",
        "ClientSecretName": "ExternalIdAppSecret1",
        "Name": "External ID App Registration 1",
        "Enabled": true
      },
      "Scopes": [ "https://graph.microsoft.com/.default" ]
    },
    "Storage": {
      "ConnectionStringOrUri": "https://your-storage-account.blob.core.windows.net",
      "AuditTableName": "migration-audit",
      "UseManagedIdentity": true
    },
    "KeyVault": {
      "VaultUri": "https://your-keyvault.vault.azure.net/",
      "UseManagedIdentity": true,
      "SecretCacheDurationMinutes": 60
    },
    "Telemetry": {
      "ConnectionString": "",
      "Enabled": true,
      "SamplingPercentage": 100.0,
      "TrackDependencies": true,
      "TrackExceptions": true
    },
    "Retry": {
      "MaxRetries": 5,
      "InitialDelayMs": 1000,
      "MaxDelayMs": 30000,
      "BackoffMultiplier": 2.0,
      "UseRetryAfterHeader": true,
      "OperationTimeoutSeconds": 120
    },
    "BatchDelayMs": 0
  }
}
