{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "Migration": {
    "B2C": {
      "TenantId": "your-b2c-tenant-id-guid",
      "TenantDomain": "contoso.onmicrosoft.com",
      "AppRegistration": {
        "ClientId": "your-b2c-app-client-id-guid",
        "ClientSecret": "your-b2c-app-client-secret",
        "Name": "B2C App Registration (Local)",
        "Enabled": true
      },
      "Scopes": [ "https://graph.microsoft.com/.default" ]
    },
    "ExternalId": {
      "TenantId": "your-externalid-tenant-id-guid",
      "TenantDomain": "externalid.onmicrosoft.com",
      "ExtensionAppId": "00000000000000000000000000000000",
      "AppRegistration": {
        "ClientId": "your-externalid-app-client-id-guid",
        "ClientSecret": "your-externalid-app-client-secret",
        "Name": "External ID App Registration (Local)",
        "Enabled": true
      },
      "Scopes": [ "https://graph.microsoft.com/.default" ]
    },
    "Storage": {
      "ConnectionStringOrUri": "UseDevelopmentStorage=true",
      "AuditTableName": "migration-audit",
      "UseManagedIdentity": false
    },
    "Telemetry": {
      "ConnectionString": "",
      "Enabled": false,
      "UseApplicationInsights": false,
      "UseConsoleLogging": true,
      "SamplingPercentage": 100.0,
      "TrackDependencies": true,
      "TrackExceptions": true
    },
    "Retry": {
      "MaxRetries": 5,
      "InitialDelayMs": 1000,
      "MaxDelayMs": 30000,
      "BackoffMultiplier": 2.0,
      "UseRetryAfterHeader": true,
      "OperationTimeoutSeconds": 120
    },
    "PhoneRegistration": {
      "QueueName": "phone-registration",
      "ThrottleDelayMs": 400,
      "MessageVisibilityTimeoutSeconds": 120,
      "EmptyQueuePollDelayMs": 5000,
      "MaxEmptyPolls": 3
    },
    "BatchDelayMs": 0
  }
}
