{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Migration": {
    "B2C": {
      "TenantId": "your-b2c-tenant-id",
      "TenantDomain": "your-tenant.onmicrosoft.com",
      "AppRegistration": {
        "ClientId": "your-b2c-client-id",
        "ClientSecretName": "B2CAppSecret",
        "Name": "B2C App Registration",
        "Enabled": true
      },
      "Scopes": [ "https://graph.microsoft.com/.default" ]
    },
    "ExternalId": {
      "TenantId": "your-external-id-tenant-id",
      "TenantDomain": "your-external-tenant.onmicrosoft.com",
      "ExtensionAppId": "00000000000000000000000000000000",
      "AppRegistration": {
        "ClientId": "your-external-id-client-id",
        "ClientSecretName": "ExternalIdAppSecret",
        "Name": "External ID App Registration",
        "Enabled": true
      },
      "Scopes": [ "https://graph.microsoft.com/.default" ]
    },
    "Storage": {
      "ConnectionStringOrUri": "UseDevelopmentStorage=true",
      "ExportContainerName": "user-exports",
      "ErrorContainerName": "migration-errors",
      "ExportBlobPrefix": "users_",
      "UseManagedIdentity": false
    },
    "KeyVault": null,
    "Telemetry": {
      "ConnectionString": "",
      "Enabled": false,
      "SamplingPercentage": 100.0,
      "TrackDependencies": true,
      "TrackExceptions": true
    },
    "Retry": {
      "MaxRetries": 5,
      "InitialDelayMs": 1000,
      "MaxDelayMs": 30000,
      "BackoffMultiplier": 2.0,
      "UseRetryAfterHeader": true,
      "OperationTimeoutSeconds": 120
    },
    "Harvest": {
      "QueueName": "user-ids-to-process",
      "IdsPerMessage": 20,
      "PageSize": 999,
      "MessageVisibilityTimeout": "00:05:00"
    },
    "Import": {
      "PhoneRegistration": {
        "EnqueuePhoneRegistration": false
      }
    },
    "PhoneRegistration": {
      "QueueName": "phone-registration",
      "ThrottleDelayMs": 1200,
      "MessageVisibilityTimeoutSeconds": 120,
      "EmptyQueuePollDelayMs": 5000,
      "MaxEmptyPolls": 3
    },
    "Export": {
      "SelectFields": "id,userPrincipalName,displayName,givenName,surname,mail,mobilePhone,identities",
      "WorkerBlobPrefix": null
    },
    "BatchSize": 100,
    "PageSize": 100,
    "VerboseLogging": false,
    "BatchDelayMs": 0
  }
}
